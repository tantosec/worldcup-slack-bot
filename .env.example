# Slack - get these from https://api.slack.com/apps
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token   # needs connections:write scope (Socket Mode)

# The Odds API - free tier (500 req/month) at https://the-odds-api.com/
# Used for live win probabilities and underdog detection (synced every 6 hours)
ODDS_API_KEY=your-api-key-here

# Channel to post results, reminders, and announcements (e.g. C0123456789 or #world-cup)
RESULTS_CHANNEL=

# Interval for all jobs: live scores, scoring, kickoff announcements, etc. (seconds, default 10)
POLL_INTERVAL=10

# Timezone for displaying kickoff times (default: Australia/Sydney = AEST/AEDT)
# Australia:  Australia/Sydney, Australia/Melbourne, Australia/Brisbane, Australia/Perth
# Europe:     Europe/London, Europe/Lisbon, Europe/Paris, Europe/Berlin, Europe/Madrid, Europe/Rome
# Americas:   America/New_York, America/Chicago, America/Denver, America/Los_Angeles
# S. America: America/Sao_Paulo, America/Buenos_Aires, America/Santiago, America/Bogota, America/Lima
# Asia:       Asia/Singapore, Asia/Tokyo, Asia/Dubai, Asia/Kolkata, Asia/Hong_Kong
# Africa:     Africa/Johannesburg, Africa/Cairo
# UTC:        UTC
DISPLAY_TIMEZONE=Australia/Sydney

# Organisation name shown in messages
ORG_NAME=TantoSec

# ── Auto-pick (LLM) ───────────────────────────────────────────────────────────
# Automatically generates predictions for players who forgot to predict a match,
# and tournament picks for anyone who missed the deadline.
# The LLM is called once at the ~1h kickoff reminder — result is cached and
# applied to all missing players at kickoff so everyone appears in the kickoff message.
# Auto-picks are labelled 🤖 everywhere they appear.

# Enable/disable auto-pick entirely (default: true)
AUTO_PICK_ENABLED=true

# LLM provider (default: pollinations — no key or account required)
# Options: pollinations | groq | google
LLM_PROVIDER=pollinations

# Required only when LLM_PROVIDER=groq — free key at console.groq.com
# GROQ_API_KEY=

# Required only when LLM_PROVIDER=google — free key at ai.google.dev
# GOOGLE_AI_API_KEY=

# Points multiplier for auto-picked match predictions (default: 0.75 = 75% of points)
# Must be a decimal between 0.0 (no points) and 1.0 (full points). Floor division is applied,
# so 9 pts × 0.75 = 6 pts. Does not affect tournament picks.
# AUTO_PICK_POINTS_MULTIPLIER=0.75

